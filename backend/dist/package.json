{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development node src/index.js",
    "dev:watch": "nodemon --watch 'src/**/*' -e js --exec 'node src/index.js'",
    "build": "npm run clean && npm run copy-assets",
    "clean": "rm -rf dist || true",
    "copy-assets": "mkdir -p dist && cp -r src/ dist/ && cp package.json dist/ && cp .env.production dist/.env",
    "start:prod": "NODE_ENV=production node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "postinstall": "npm run prisma:generate",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --fix",
    "docker:build": "docker build -t your-app-name .",
    "docker:run": "docker run -p 4000:4000 -d your-app-name"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "graphql": "^16.10.0",
    "graphql-http": "^1.22.4",
    "graphql-subscriptions": "^3.0.0",
    "graphql-tag": "^2.12.6",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^16.0.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
